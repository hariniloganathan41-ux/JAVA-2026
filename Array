        int arr[]={1,1,5,1,3,7,0,2};
        int target=6;
        for(int i=0;i<arr.length;i++){
            for(int j=i+1;j<arr.length;j++){
                for(int k=j+1;k<arr.length;k++){
                    
                if(arr[i]+arr[j]+arr[k] == target){
                    System.out.println("("+arr[i]+","+arr[j]+","+arr[k]+")");
                    break;
                }
                }
            }
        }
    }
}

