        Scanner sc=new Scanner(System.in);
         System.out.println("Even numbers are : ");
        for(int i=0;i<101;i++){
            if(i%2==0){
                System.out.println(i+" ");
            }
        }
        System.out.println("Odd numbers are : ");
        for(int i=0;i<101;i++){
            if(i%2!=0){
                System.out.println(i+" ");
            }
        }
    }
}


